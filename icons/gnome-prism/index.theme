[Icon Theme]
Name=gnome-prism
Comment=gnome-prism icon theme (inherits Adwaita)
Inherits=Adwaita
Directories=256x256/apps,scalable/apps,scalable/status

[256x256/apps]
Size=256
Context=Applications
Type=Fixed

[scalable/apps]
Size=16
Context=Applications
Type=Scalable
MinSize=16
MaxSize=512

[scalable/status]
Size=16
Context=Status
Type=Scalable
MinSize=16
MaxSize=512
