{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "gnome-prism (Firefox)",
  "description": "Firefox theme companion for gnome-prism.",
  "author": "gnome-prism",
  "theme": {
    "colors": {
      "frame": "#06060a",
      "frame_inactive": "#040406",
      "tab_background_text": "#bda7f0",
      "tab_text": "#bda7f0",
      "tab_selected": "#000000",
      "tab_line": "#ff7447",
      "toolbar": "#000000",
      "toolbar_text": "#bda7f0",
      "icons": "#bda7f0",
      "icons_attention": "#ff7447",
      "bookmark_text": "#bda7f0",
      "button_background_hover": "#191919",
      "button_background_active": "#bda7f0",
      "toolbar_field": "#000000",
      "toolbar_field_text": "#bda7f0",
      "toolbar_field_border": "#bda7f0",
      "toolbar_field_border_focus": "#ff7447",
      "toolbar_field_focus": "#08080c",
      "toolbar_field_text_focus": "#e3d9ff",
      "toolbar_field_highlight": "#bda7f0",
      "toolbar_field_highlight_text": "#000000",
      "toolbar_top_separator": "#bda7f0",
      "toolbar_bottom_separator": "#bda7f0",
      "toolbar_vertical_separator": "#bda7f0",
      "popup": "#000000",
      "popup_text": "#bda7f0",
      "popup_border": "#bda7f0",
      "popup_highlight": "#191919",
      "popup_highlight_text": "#e3d9ff",
      "sidebar": "#000000",
      "sidebar_text": "#bda7f0",
      "sidebar_border": "#bda7f0",
      "sidebar_highlight": "#191919",
      "sidebar_highlight_text": "#e3d9ff",
      "ntp_background": "#000000",
      "ntp_card_background": "#08080c",
      "ntp_text": "#bda7f0"
    },
    "properties": {
      "color_scheme": "dark",
      "content_color_scheme": "dark"
    }
  }
}
