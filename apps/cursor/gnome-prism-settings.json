  "editor.tokenColorCustomizations": {
    "[Default High Contrast]": {
      "textMateRules": [
        {
          "name": "Force Lavender",
          "scope": [
            "source",
            "variable",
            "keyword",
            "storage.type",
            "support.variable",
            "punctuation",
            "meta.brace",
            "keyword.operator"
          ],
          "settings": {
            "foreground": "#BDA7F0"
          }
        },
        {
          "name": "Orange: Structural Code (Keywords, Functions, Numbers)",
          "scope": [
            "keyword",
            "storage",
            "type",
            "entity.name.function",
            "support.function",
            "entity.name.type",
            "support.type",
            "support.class",
            "constant.numeric",
            "constant.language",
            "entity.name.tag",
            "entity.other.attribute-name",
            "meta.function-call"
          ],
          "settings": {
            "foreground": "#FF7447"
          }
        }
      ]
    }
  }
